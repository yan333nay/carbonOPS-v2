# Canva Connect API — Credentials
# Copie este arquivo para .env e preencha com suas credentials reais
# NUNCA commite o arquivo .env

CANVA_CLIENT_ID=seu_client_id_aqui
CANVA_CLIENT_SECRET=seu_client_secret_aqui

# OAuth redirect URI (configure no Canva Developer Portal)
CANVA_REDIRECT_URI=http://127.0.0.1:3000/auth/canva/callback

# Scopes necessarios para o social-media-squad
# design:content:read design:content:write asset:read asset:write
CANVA_SCOPES=design:content:read,design:content:write,asset:read,asset:write

# ---------------------------------------------------------------
# Meta Graph API — Instagram Business
# Setup: developers.facebook.com → seu app → Instagram Graph API
# ---------------------------------------------------------------
META_ACCESS_TOKEN=seu_user_access_token_aqui
INSTAGRAM_BUSINESS_ACCOUNT_ID=seu_ig_business_account_id_aqui

# ---------------------------------------------------------------
# Unsplash API (opcional — sem isso usa fotos curadas do acervo)
# Setup: unsplash.com/developers → New Application → Access Key
# ---------------------------------------------------------------
UNSPLASH_ACCESS_KEY=seu_access_key_aqui
